# Copy to .env.local and fill in values:
#   copy .env.example .env.local        (Windows)
#   cp .env.example .env.local          (Linux/macOS)

# Database — must match run.bat db / run.sh db Docker container
DATABASE_URL=postgresql://postgres:password@localhost:5432/blog

# GitHub (public repos + profile)
GITHUB_TOKEN=
NEXT_PUBLIC_GITHUB_USER=

# Site
NEXT_PUBLIC_SITE_OWNER=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_FEATURED_WORK=

# Admin (/admin login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Visitor accounts — Cloudflare Turnstile captcha (signup)
# Dev test keys (always pass): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: English post translation
# DEEPL_API_KEY=

# Local dev — hide banner, skip prod-only noise
DEV_MODE=true
NEXT_PUBLIC_DEV_MODE=true

# Server only (run.sh / PM2)
APP_NAME=kristiansen
APP_DIR=/var/www/kristiansen.icu
# SITE_DOMAIN=kristiansen.icu
# APP_PORT=3000

# Optional site-wide banner
# NEXT_PUBLIC_BANNER=
