# Copy to .env.local and fill in values:
#   copy .env.example .env.local        (Windows)
#   cp .env.example .env.local          (Linux/macOS)
#
# Most API keys & integration defaults live in api-config.ts (project root).
# .env.local overrides api-config when the same variable is set here.

# Database — must match run.bat db / run.sh db Docker container
DATABASE_URL=postgresql://postgres:password@localhost:5432/blog
# DATABASE_SSL=true                    # TLS to Postgres (auto-on in production)
# DATABASE_POOL_MAX=10

# Security — REQUIRED in production (generate: openssl rand -hex 32)
# DATA_ENCRYPTION_KEY=

# Optional overrides (otherwise use api-config.ts defaults)
# NEXT_PUBLIC_SITE_OWNER=
# NEXT_PUBLIC_CONTACT_EMAIL=
# NEXT_PUBLIC_GITHUB_USER=
# GITHUB_TOKEN=
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# RESEND_API_KEY=
# EMAIL_FROM=verify@yourdomain.com
# SITE_URL=https://kristiansen.icu
# MAIL_USE_SANDBOX=true                # optional: onboarding@resend.dev (Resend login email only)
# DEEPL_API_KEY=

# Local dev — hide banner, skip prod-only noise
DEV_MODE=true
NEXT_PUBLIC_DEV_MODE=true

# Server only (run.sh / PM2)
APP_NAME=kristiansen
APP_DIR=/var/www/kristiansen.icu
# SITE_DOMAIN=kristiansen.icu
# APP_PORT=3000

# Optional site-wide banner
# NEXT_PUBLIC_BANNER=
